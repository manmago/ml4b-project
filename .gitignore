# =============================================================================
# Python
# =============================================================================
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/

# =============================================================================
# Virtual Environments (uv / venv / conda)
# =============================================================================
.venv/
venv/
env/
ENV/
.conda/

# uv lock file is committed (ensures reproducibility across team)
# uv.lock → DO NOT add here

# =============================================================================
# Jupyter Notebooks — Outputs & Checkpoints
# =============================================================================
.ipynb_checkpoints/
# Uncomment if you want to ignore notebook outputs (recommended for clean diffs):
# *.ipynb  → don't ignore notebooks themselves, but strip outputs via nbstripout

# =============================================================================
# Data — NEVER commit raw sensor data or large files to git
# Use DVC, Git LFS, or a shared drive instead
# =============================================================================
data/raw/
data/processed/*
!data/processed/.gitkeep
!data/processed/README.md
data/external/
# User-correction feedback for continual learning (DECISIONS.md §8) — the end
# user's own labelled data, kept local and never committed.
data/feedback/
*.parquet
*.h5
*.hdf5
*.pkl
*.pickle
*.npy
*.npz
# Exception: small fixture/sample files for tests
!tests/fixtures/*.csv

# =============================================================================
# ML Models — large binary files, use model registry instead
# =============================================================================
# Use models/saved/* (not models/saved/) so specific files can be re-included
# below — git cannot re-include a file whose parent directory is excluded.
models/saved/*
*.joblib
*.pt
*.pth
*.onnx
*.pb

# =============================================================================
# Streamlit
# =============================================================================
.streamlit/secrets.toml     # Secrets NEVER in git!

# =============================================================================
# Environment Variables & Secrets
# =============================================================================
.env
.env.*
!.env.example               # Template with dummy values is OK
*.key
*.pem
secrets/

# =============================================================================
# VS Code
# =============================================================================
.vscode/
!.vscode/settings.json      # Shared workspace settings are OK
!.vscode/extensions.json    # Recommended extensions list is OK

# =============================================================================
# macOS
# =============================================================================
.DS_Store
.AppleDouble
.LSOverride
._*

# =============================================================================
# Windows
# =============================================================================
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# =============================================================================
# Linux / WSL
# =============================================================================
*~
.nfs*

# =============================================================================
# Testing & Coverage
# =============================================================================
.pytest_cache/
.coverage
htmlcov/
coverage.xml
*.cover

# =============================================================================
# Type Checking
# =============================================================================
.mypy_cache/
.dmypy.json
dmypy.json

# =============================================================================
# Reports — generated figures and result summaries
# Ignore file contents but keep .gitkeep placeholders so folder is tracked
# =============================================================================
reports/**
!reports/**/
!reports/**/.gitkeep

# =============================================================================
# Logs & Temp Files
# =============================================================================
*.log
*.tmp
*.bak
logs/
tmp/

# =============================================================================
# Trained model + feature names — COMMITTED so the Streamlit app works after a
# fresh clone with no dataset download. These negations come last so they win
# over the broad models/saved/*, *.joblib and data/processed/* rules above.
# =============================================================================
!models/saved/best_model.joblib
!models/saved/random_forest.joblib
!models/saved/novelty_detector.joblib
!models/saved/model_metrics.json
# Model 1 (baseline, Kaggle only) — shipped alongside Model 2 so the app can show
# the effect of our own uploaded training data side by side (DECISIONS.md).
!models/saved/baseline_model.joblib
!models/saved/baseline_novelty_detector.joblib
!models/saved/baseline_metrics.json
!data/processed/feature_names.txt

# Local-only developer tooling — kept on disk, intentionally not tracked.
CLAUDE.md
agents/
TEAM_PRAESENTATION.md

# Sailboat-Retrospektiven — lokale Team-Reflexionen, nicht ins Repo
Sailboats/

# Autonome Nacht-Arbeitsprotokolle — lokale Notizen, nicht ins Repo
Nightsession_LOG.md
Night_log.md
